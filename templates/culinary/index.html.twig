{% extends 'base.html.twig' %}

{% block title %}Кулинарные рецепты{% endblock %}
{% block head %}
{{parent()}}
{% endblock %}
{% block stylesheets %}
  <link href="{{ asset('build/app.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
</br>

{% for row in recipes|batch(4) %}
        <div class="row">
            {% for recipe in row %}
                <div class="col-12 col-md-6 col-lg-3 mb-4">
                    <div class="card border shadow lift card text-center">
                      <div class="card-body">
                        {% if not recipe.getPhotoFilename == null %}
                        <img src="{{vich_uploader_asset(recipe)}}" class="card-img-top" alt="{{recipe.title}}">
                        {% endif %}
                         <div class="card-title">
                                <h4 class="font-weight-light">
                                    {{ recipe.title }}
                                </h4>
                            </div>
                             <p class="card-text">{{ recipe.description }}</p>
                             <hr/>
                             <!-- Button -->
                             <a class="btn btn-primary" href="{{ path('cooking',{'title': recipe.title}) }}" role="button">Приготовление</a>
                             <!-- <p class="card-text">{{ recipe.recipe_cooking |raw }}</p> -->
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endfor %}
{% endblock %}
